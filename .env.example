DATABASE_URL=            # Pooled connection, app runtime (Supabase transaction pooler :6543 + ?pgbouncer=true)
DIRECT_URL=              # Direct connection, migrations only (Supabase :5432). Same as DATABASE_URL for local Postgres.
PAYSTACK_SECRET_KEY=     # test key first
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
ARKESEL_API_KEY=
ARKESEL_SENDER_ID=
AUTH_SECRET=             # openssl rand -base64 32
ADMIN_EMAIL=             # seed
ADMIN_PASSWORD=          # seed, hashed on first run
NEXT_PUBLIC_APP_URL=     # the Vercel URL, needed for Paystack callback
